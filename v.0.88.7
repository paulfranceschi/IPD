            },
            omega_tft: (history) => {
                // Cooperate on the first move
                if (history.length === 0) return 'cooperate';

                // TFT on round 2
                if (history.length === 1) return history[0].opponent;

                let move;

                // Are we deadlocked? (in a CD -> DC loop)
                if (omegaTftState.deadlockCounter >= omegaTftDeadlockThreshold) {
                    move = 'cooperate';
                    if (omegaTftState.deadlockCounter === omegaTftDeadlockThreshold) {
                        omegaTftState.deadlockCounter = omegaTftDeadlockThreshold + 1;
                    } else {
