<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iterated Prisoner's Dilemma Simulation</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }
        .gradient-bg {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        .card-shadow {
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        }
        .strategy-card {
            transition: all 0.3s ease;
        }
        .strategy-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }
        .strategy-card.selected {
            border-color: #667eea;
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        }
        .progress-bar {
            transition: width 0.3s ease;
        }
        .result-bar {
            transition: all 0.5s ease;
        }
        .strategy-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 8px;
            max-height: 400px;
            overflow-y: auto;
            padding: 4px;
        }
        .strategy-grid::-webkit-scrollbar {
            width: 6px;
        }
        .strategy-grid::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 3px;
        }
        .strategy-grid::-webkit-scrollbar-thumb {
            background: #c1c1c1;
            border-radius: 3px;
        }
        .tournament-row:hover {
            background-color: #f3f4f6;
        }
        .tournament-row.winner {
            background: linear-gradient(135deg, rgba(255, 215, 0, 0.3) 0%, rgba(255, 193, 7, 0.1) 100%);
        }
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .modal-overlay.active {
            display: flex;
        }
        .modal-content {
            background: white;
            border-radius: 1rem;
            padding: 2rem;
            max-width: 500px;
            width: 90%;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen">
    <div class="gradient-bg py-8">
        <div class="container mx-auto px-4">
            <div class="text-center text-white">
                <h1 class="text-4xl font-bold mb-2">Iterated Prisoner's Dilemma</h1>
                <p class="text-lg opacity-90">Game Theory Simulation</p>
            </div>
        </div>
    </div>

    <div class="container mx-auto px-4 py-8">
        <!-- Game Image -->
        <div class="mb-8 flex justify-center">
            <img src="https://image.qwenlm.ai/public_source/67c273f5-0f5a-457a-8520-366a3122d5ee/178f2ed61-69dc-4306-8c8a-acf9041e7b5f.png" 
                 alt="Prisoner's Dilemma Logo" 
                 class="max-w-md rounded-lg shadow-lg bg-white p-4">
        </div>

        <!-- Payoff Matrix -->
        <div class="bg-white rounded-xl card-shadow p-6 mb-8">
            <h2 class="text-2xl font-bold text-gray-800 mb-4">Payoff Matrix</h2>
            <div class="overflow-x-auto">
                <table class="w-full max-w-lg mx-auto border-collapse">
                    <thead>
                        <tr>
                            <th class="p-3"></th>
                            <th class="p-3 bg-blue-100 text-blue-800 font-semibold">Player 2 Cooperates</th>
                            <th class="p-3 bg-red-100 text-red-800 font-semibold">Player 2 Defects</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="p-3 bg-blue-100 text-blue-800 font-semibold">Player 1 Cooperates</td>
                            <td class="p-3 text-center bg-green-50">
                                <span class="font-bold text-green-700">3, 3</span>
                                <p class="text-xs text-gray-500">Reward (R)</p>
                            </td>
                            <td class="p-3 text-center bg-yellow-50">
                                <span class="font-bold text-yellow-700">0, 5</span>
                                <p class="text-xs text-gray-500">Sucker (S)</p>
                            </td>
                        </tr>
                        <tr>
                            <td class="p-3 bg-red-100 text-red-800 font-semibold">Player 1 Defects</td>
                            <td class="p-3 text-center bg-yellow-50">
                                <span class="font-bold text-yellow-700">5, 0</span>
                                <p class="text-xs text-gray-500">Temptation (T)</p>
                            </td>
                            <td class="p-3 text-center bg-orange-50">
                                <span class="font-bold text-orange-700">1, 1</span>
                                <p class="text-xs text-gray-500">Punishment (P)</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Configuration -->
        <div class="grid md:grid-cols-2 gap-8 mb-8">
            <!-- Player 1 -->
            <div class="bg-white rounded-xl card-shadow p-6">
                <h3 class="text-xl font-bold text-blue-600 mb-4 flex items-center">
                    <span class="w-8 h-8 bg-blue-500 text-white rounded-full flex items-center justify-center mr-2">1</span>
                    Player 1 Strategy
                </h3>
                <div class="strategy-grid" id="player1-strategies">
                    <!-- Strategies will be populated by JS -->
                </div>
            </div>

            <!-- Player 2 -->
            <div class="bg-white rounded-xl card-shadow p-6">
                <h3 class="text-xl font-bold text-red-600 mb-4 flex items-center">
                    <span class="w-8 h-8 bg-red-500 text-white rounded-full flex items-center justify-center mr-2">2</span>
                    Player 2 Strategy
                </h3>
                <div class="strategy-grid" id="player2-strategies">
                    <!-- Strategies will be populated by JS -->
                </div>
            </div>
        </div>

        <!-- Iteration Settings -->
        <div class="bg-white rounded-xl card-shadow p-6 mb-8">
            <h3 class="text-xl font-bold text-gray-800 mb-4">Simulation Settings</h3>
            <div class="flex flex-wrap items-center gap-6">
                <div class="flex-1 min-w-64">
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Number of Iterations: <span id="iteration-value" class="font-bold text-purple-600">200</span>
                    </label>
                    <input type="range" id="iterations" min="10" max="1000" value="200" step="10"
                           class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600">
                </div>
                <div class="flex-1 min-w-64">
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Iteration Deviation: <span id="deviation-value" class="font-bold text-purple-600">5%</span>
                    </label>
                    <input type="range" id="deviation" min="0" max="50" value="5" step="1"
                           class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600">
                    <p class="text-xs text-gray-500 mt-1">Random variation in iterations per simulation (±%)</p>
                </div>
                <div class="flex-1 min-w-64">
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Trials: <span id="trials-value" class="font-bold text-purple-600">5</span>
                    </label>
                    <input type="range" id="trials" min="1" max="100" value="5" step="1"
                           class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600">
                    <p class="text-xs text-gray-500 mt-1">Number of tournaments to run and average</p>
                </div>
                <div class="flex-1 min-w-64">
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Generous Tit-For-Tat Forgiveness: <span id="generous-value" class="font-bold text-purple-600">33%</span>
                    </label>
                    <input type="range" id="generous" min="0" max="100" value="33" step="1"
                           class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600">
                </div>
                <div class="flex-1 min-w-64">
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Random with Probability (Cooperate): <span id="random-prob-value" class="font-bold text-purple-600">33%</span>
                    </label>
                    <input type="range" id="random-prob" min="0" max="100" value="33" step="1"
                           class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600">
                </div>
                <div class="flex-1 min-w-64">
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Imperfect TFT Probability: <span id="imperfect-tft-value" class="font-bold text-purple-600">90%</span>
                    </label>
                    <input type="range" id="imperfect-tft" min="50" max="100" value="90" step="1"
                           class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600">
                    <p class="text-xs text-gray-500 mt-1">Probability of copying opponent's last move</p>
                </div>
                <div class="flex-1 min-w-64">
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Reactive Strategy - p (after C): <span id="reactive-p-value" class="font-bold text-purple-600">90%</span>
                    </label>
                    <input type="range" id="reactive-p" min="0" max="100" value="90" step="1"
                           class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600">
                    <p class="text-xs text-gray-500 mt-1">Probability of cooperating after opponent cooperates</p>
                </div>
                <div class="flex-1 min-w-64">
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Reactive Strategy - q (after D): <span id="reactive-q-value" class="font-bold text-purple-600">10%</span>
                    </label>
                    <input type="range" id="reactive-q" min="0" max="100" value="10" step="1"
                           class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600">
                    <p class="text-xs text-gray-500 mt-1">Probability of cooperating after opponent defects</p>
                </div>
                <div class="flex-1 min-w-64">
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Noise Probability: <span id="noise-value" class="font-bold text-purple-600">0.3%</span>
                    </label>
                    <input type="range" id="noise" min="0" max="20" value="0.3" step="0.1"
                           class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600">
                    <p class="text-xs text-gray-500 mt-1">Chance of move being flipped (error/miscommunication)</p>
                </div>
                <div class="flex-1 min-w-64">
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Gradual TFT Apologies: <span id="gradual-apologies-value" class="font-bold text-purple-600">2</span>
                    </label>
                    <input type="range" id="gradual-apologies" min="0" max="10" value="2" step="1"
                           class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600">
                    <p class="text-xs text-gray-500 mt-1">Number of cooperation rounds after punishment (0 = no apologies)</p>
                </div>
                <div class="flex-1 min-w-64">
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Fully Gradual TFT Apologies Max: <span id="fully-gradual-apologies-max-value" class="font-bold text-purple-600">6</span>
                    </label>
                    <input type="range" id="fully-gradual-apologies-max" min="1" max="20" value="6" step="1"
                           class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-purple-600">
                    <p class="text-xs text-gray-500 mt-1">Max apologies; actual = max - defection_count (min 0)</p>
                </div>
            </div>
        </div>

        <!-- Control Buttons -->
        <div class="flex flex-wrap gap-4 justify-center mb-8">
            <button id="run-btn" class="bg-gradient-to-r from-purple-500 to-indigo-600 text-white px-8 py-3 rounded-lg font-semibold hover:from-purple-600 hover:to-indigo-700 transition-all transform hover:scale-105 shadow-lg">
                🎮 Run Simulation
            </button>
            <button id="tournament-btn" class="bg-gradient-to-r from-orange-500 to-amber-600 text-white px-8 py-3 rounded-lg font-semibold hover:from-orange-600 hover:to-amber-700 transition-all transform hover:scale-105 shadow-lg">
                🏆 Run Tournament
            </button>
            <button id="reset-btn" class="bg-gray-200 text-gray-700 px-8 py-3 rounded-lg font-semibold hover:bg-gray-300 transition-all">
                🔄 Reset
            </button>
            <button id="about-btn" class="bg-gradient-to-r from-teal-500 to-cyan-600 text-white px-8 py-3 rounded-lg font-semibold hover:from-teal-600 hover:to-cyan-700 transition-all transform hover:scale-105 shadow-lg">
                ℹ️ About
            </button>
        </div>

        <!-- Progress -->
        <div id="progress-container" class="bg-white rounded-xl card-shadow p-6 mb-8 hidden">
            <div class="flex justify-between items-center mb-2">
                <span class="text-sm font-medium text-gray-700" id="progress-label">Progress</span>
                <span id="progress-text" class="text-sm font-medium text-gray-700">0 / 200</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-4 mb-2">
                <div id="progress-bar" class="progress-bar bg-gradient-to-r from-purple-500 to-indigo-600 h-4 rounded-full" style="width: 0%"></div>
            </div>
            <!-- Trial progress bar (only shown when trials > 1) -->
            <div id="trial-progress-container" class="hidden">
                <div class="flex justify-between items-center mb-1">
                    <span class="text-xs text-gray-500">Trial Progress</span>
                    <span id="trial-progress-text" class="text-xs text-gray-500">Trial 1 / 5</span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-3">
                    <div id="trial-progress-bar" class="progress-bar bg-gradient-to-r from-orange-400 to-red-500 h-3 rounded-full" style="width: 0%"></div>
                </div>
            </div>
        </div>

        <!-- Results -->
        <div id="results-container" class="bg-white rounded-xl card-shadow p-6 mb-8 hidden">
            <h3 class="text-2xl font-bold text-gray-800 mb-6 text-center">Simulation Results</h3>
            
            <!-- Score Cards -->
            <div class="grid md:grid-cols-2 gap-6 mb-8">
                <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg p-6 text-center">
                    <h4 class="text-lg font-semibold text-blue-700 mb-2">Player 1 Total Score</h4>
                    <p id="player1-score" class="text-4xl font-bold text-blue-600">0</p>
                    <p id="player1-average" class="text-sm text-blue-500 mt-1">Average: 0 per turn</p>
                </div>
                <div class="bg-gradient-to-br from-red-50 to-red-100 rounded-lg p-6 text-center">
                    <h4 class="text-lg font-semibold text-red-700 mb-2">Player 2 Total Score</h4>
                    <p id="player2-score" class="text-4xl font-bold text-red-600">0</p>
                    <p id="player2-average" class="text-sm text-red-500 mt-1">Average: 0 per turn</p>
                </div>
            </div>

            <!-- Cooperation Stats -->
            <div class="grid md:grid-cols-2 gap-6 mb-8">
                <div class="bg-gray-50 rounded-lg p-4">
                    <h4 class="font-semibold text-gray-700 mb-3">Cooperation Rate</h4>
                    <div class="flex items-center gap-4">
                        <div class="flex-1">
                            <div class="flex justify-between text-sm mb-1">
                                <span class="text-blue-600">Player 1</span>
                                <span id="player1-coop" class="font-medium">0%</span>
                            </div>
                            <div class="w-full bg-gray-200 rounded-full h-3">
                                <div id="player1-coop-bar" class="result-bar bg-blue-500 h-3 rounded-full" style="width: 0%"></div>
                            </div>
                        </div>
                        <div class="flex-1">
                            <div class="flex justify-between text-sm mb-1">
                                <span class="text-red-600">Player 2</span>
                                <span id="player2-coop" class="font-medium">0%</span>
                            </div>
                            <div class="w-full bg-gray-200 rounded-full h-3">
                                <div id="player2-coop-bar" class="result-bar bg-red-500 h-3 rounded-full" style="width: 0%"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-gray-50 rounded-lg p-4">
                    <h4 class="font-semibold text-gray-700 mb-3">Outcome Distribution</h4>
                    <div class="grid grid-cols-2 gap-2 text-sm">
                        <div class="bg-green-100 p-2 rounded text-center">
                            <p class="font-semibold text-green-700" id="both-coop">0</p>
                            <p class="text-green-600">Both Cooperate</p>
                        </div>
                        <div class="bg-orange-100 p-2 rounded text-center">
                            <p class="font-semibold text-orange-700" id="both-defect">0</p>
                            <p class="text-orange-600">Both Defect</p>
                        </div>
                        <div class="bg-yellow-100 p-2 rounded text-center">
                            <p class="font-semibold text-yellow-700" id="p1-coop-p2-defect">0</p>
                            <p class="text-yellow-600">P1 C, P2 D</p>
                        </div>
                        <div class="bg-yellow-100 p-2 rounded text-center">
                            <p class="font-semibold text-yellow-700" id="p1-defect-p2-coop">0</p>
                            <p class="text-yellow-600">P1 D, P2 C</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Winner -->
            <div id="winner-container" class="text-center p-4 rounded-lg hidden">
                <p class="text-xl font-bold" id="winner-text"></p>
            </div>
        </div>

        <!-- Tournament Results -->
        <div id="tournament-container" class="bg-white rounded-xl card-shadow p-6 mb-8 hidden">
            <h3 class="text-2xl font-bold text-gray-800 mb-2 text-center">🏆 Tournament Results</h3>
            <p class="text-gray-600 text-center mb-6">
                <span id="tournament-trials-text"></span>
                Each strategy plays against all others (including itself) with <span id="tournament-iterations" class="font-semibold">200</span> ± <span id="tournament-deviation" class="font-semibold">5%</span> iterations
            </p>
            
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-gradient-to-r from-orange-100 to-amber-100">
                            <th class="p-3 text-left rounded-tl-lg">Rank</th>
                            <th class="p-3 text-left">Strategy</th>
                            <th class="p-3 text-center">Total Score</th>
                            <th class="p-3 text-center">Avg Score</th>
                            <th class="p-3 text-center">Wins</th>
                            <th class="p-3 text-center">Losses</th>
                            <th class="p-3 text-center">Ties</th>
                            <th class="p-3 text-center rounded-tr-lg">Coop Rate</th>
                        </tr>
                    </thead>
                    <tbody id="tournament-body">
                        <!-- Will be populated by JS -->
                    </tbody>
                </table>
            </div>

            <!-- Matchup Matrix -->
            <div class="mt-8">
                <h4 class="text-lg font-bold text-gray-800 mb-4">Score Matrix (Row vs Column)</h4>
                <div class="overflow-x-auto">
                    <table class="w-full text-xs" id="matrix-table">
                        <!-- Will be populated by JS -->
                    </table>
                </div>
            </div>
        </div>

        <!-- Turn History -->
        <div id="history-container" class="bg-white rounded-xl card-shadow p-6 mb-8 hidden">
            <h3 class="text-xl font-bold text-gray-800 mb-4">Recent Turns (Last 20)</h3>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-gray-100">
                            <th class="p-2 text-left">Turn</th>
                            <th class="p-2 text-left">Player 1</th>
                            <th class="p-2 text-left">Player 2</th>
                            <th class="p-2 text-left">P1 Score</th>
                            <th class="p-2 text-left">P2 Score</th>
                        </tr>
                    </thead>
                    <tbody id="history-body">
                        <!-- Will be populated by JS -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- About Modal -->
    <div id="about-modal" class="modal-overlay">
        <div class="modal-content">
            <div class="text-center mb-6">
                <h2 class="text-3xl font-bold text-gray-800 mb-2">Iterated Prisoner's Dilemma</h2>
                <p class="text-lg text-purple-600 font-semibold">Version 0.88.7</p>
            </div>
            
            <div class="space-y-4 text-gray-700">
                <div class="flex items-start gap-3 p-3 bg-purple-50 rounded-lg">
                    <span class="text-2xl">👤</span>
                    <div>
                        <p class="font-semibold text-gray-800">Author</p>
                        <p>Paul Franceschi</p>
                        <p class="text-xs text-gray-600 mt-2">Experimental test based on the paper:<br>
                        <a href="https://philarchive.org/rec/FRACCP" target="_blank" class="text-purple-600 hover:underline break-all">Cadre conceptuel pour la résolution d'une classe de conflits de valeurs</a>
                        </p>
                    </div>
                </div>
                
                <div class="flex items-center gap-3 p-3 bg-blue-50 rounded-lg">
                    <span class="text-2xl">🤖</span>
                    <div>
                        <p class="font-semibold text-gray-800">Made with</p>
                        <p>Qwen 3.5-Plus</p>
                    </div>
                </div>
                
                <div class="flex items-center gap-3 p-3 bg-green-50 rounded-lg">
                    <span class="text-2xl">📜</span>
                    <div>
                        <p class="font-semibold text-gray-800">License</p>
                        <p>MIT License</p>
                    </div>
                </div>
                
                <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg">
                    <span class="text-2xl">📦</span>
                    <div>
                        <p class="font-semibold text-gray-800">GitHub Repository</p>
                        <a href="https://github.com/paulfranceschi/IPD" target="_blank" rel="noopener noreferrer" 
                           class="text-purple-600 hover:text-purple-800 underline break-all">
                            https://github.com/paulfranceschi/IPD
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="mt-6 text-center">
                <p class="text-sm text-gray-500 mb-4">
                    A comprehensive simulation of the Iterated Prisoner's Dilemma with 30 different strategies.
                </p>
                <button id="close-modal-btn" class="bg-gradient-to-r from-purple-500 to-indigo-600 text-white px-6 py-2 rounded-lg font-semibold hover:from-purple-600 hover:to-indigo-700 transition-all">
                    Close
                </button>
            </div>
        </div>
    </div>

    <script>
        // Strategy definitions (30 strategies total)
        const strategies = [
            { id: 'always_cooperate', name: 'Always Cooperate', description: 'Always chooses to cooperate' },
            { id: 'always_defect', name: 'Always Defect', description: 'Always chooses to defect' },
            { id: 'random', name: 'Random (50/50)', description: 'Randomly cooperates or defects (50/50)' },
            { id: 'random_prob', name: 'Random with Probability', description: 'Cooperates with configurable probability' },
