                        <div class="flex-1">
                            <p class="font-semibold text-gray-800 text-sm">${strategy.name}</p>
                            <p class="text-xs text-gray-500 mt-1">${strategy.description}</p>
                        </div>
                        <div class="w-4 h-4 rounded-full border-2 flex-shrink-0 ml-2 ${selectedP1 === strategy.id ? 'bg-purple-500 border-purple-500' : 'border-gray-300'}"></div>
                    </div>
                `;
                p1Card.addEventListener('click', () => selectStrategy(1, strategy.id));
                p1Container.appendChild(p1Card);

                const p2Card = document.createElement('div');
                p2Card.className = `strategy-card p-3 rounded-lg border-2 cursor-pointer ${selectedP2 === strategy.id ? 'selected border-purple-500' : 'border-gray-200'}`;
                p2Card.innerHTML = `
                    <div class="flex items-center justify-between">
                        <div class="flex-1">
                            <p class="font-semibold text-gray-800 text-sm">${strategy.name}</p>
                            <p class="text-xs text-gray-500 mt-1">${strategy.description}</p>
                        </div>
                        <div class="w-4 h-4 rounded-full border-2 flex-shrink-0 ml-2 ${selectedP2 === strategy.id ? 'bg-purple-500 border-purple-500' : 'border-gray-300'}"></div>
                    </div>
                `;
                p2Card.addEventListener('click', () => selectStrategy(2, strategy.id));
                p2Container.appendChild(p2Card);
            });
        }

        function selectStrategy(player, strategyId) {
            if (player === 1) selectedP1 = strategyId;
            else selectedP2 = strategyId;
            initializeStrategySelectors();
        }

        function runMatch(strategy1, strategy2, numIterations, noise) {
            // Reset OmegaTFT state for new match
            omegaTftState = { deadlockCounter: 0, randomnessCounter: 0 };
            
            let history = [];
            let p1Score = 0, p2Score = 0, p1CoopCount = 0, p2CoopCount = 0;

            for (let turn = 0; turn < numIterations; turn++) {
                const p1History = history.map(h => ({ opponent: h.p2, self: h.p1 }));
                const p2History = history.map(h => ({ opponent: h.p1, self: h.p2 }));
                const lastP1Payoff = history.length > 0 ? history[history.length - 1].p1Score : null;
                const lastP2Payoff = history.length > 0 ? history[history.length - 1].p2Score : null;
                
                let p1Move = strategyFunctions[strategy1](p1History, lastP1Payoff);
                let p2Move = strategyFunctions[strategy2](p2History, lastP2Payoff);

                p1Move = applyNoise(p1Move, noise);
                p2Move = applyNoise(p2Move, noise);

                const payoffKey = `${p1Move}_${p2Move}`;
                const payoff = payoffs[payoffKey];

                p1Score += payoff.p1;
                p2Score += payoff.p2;
                if (p1Move === 'cooperate') p1CoopCount++;
                if (p2Move === 'cooperate') p2CoopCount++;

                history.push({ turn: turn + 1, p1: p1Move, p2: p2Move, p1Score: payoff.p1, p2Score: payoff.p2 });
            }

            return { p1Score, p2Score, p1CoopRate: (p1CoopCount / numIterations) * 100, p2CoopRate: (p2CoopCount / numIterations) * 100, actualIterations: numIterations };
        }

        function runTournament() {
            const progressContainer = document.getElementById('progress-container');
            const resultsContainer = document.getElementById('results-container');
            const historyContainer = document.getElementById('history-container');
            const tournamentContainer = document.getElementById('tournament-container');
            
            progressContainer.classList.remove('hidden');
            resultsContainer.classList.add('hidden');
            historyContainer.classList.add('hidden');
            tournamentContainer.classList.add('hidden');

            const progressBar = document.getElementById('progress-bar');
            const progressText = document.getElementById('progress-text');
            const progressLabel = document.getElementById('progress-label');
            const trialProgressContainer = document.getElementById('trial-progress-container');
            const trialProgressBar = document.getElementById('trial-progress-bar');
            const trialProgressText = document.getElementById('trial-progress-text');
            
            if (trials > 1) trialProgressContainer.classList.remove('hidden');
            else trialProgressContainer.classList.add('hidden');
            
            progressLabel.textContent = 'Tournament Progress';
            const totalMatches = strategies.length * strategies.length;
            
            const accumulatedResults = strategies.map(s => ({
                id: s.id, name: s.name, totalScore: 0, wins: 0, losses: 0, ties: 0,
                totalCoop: 0, totalIterations: 0, matches: 0, scores: {}
            }));

            const scoreMatrix = {};
            strategies.forEach(s1 => {
                scoreMatrix[s1.id] = {};
                strategies.forEach(s2 => { scoreMatrix[s1.id][s2.id] = 0; });
            });

            function runTrial(trialNum) {
                if (trials > 1) {
                    const trialProgress = (trialNum / trials) * 100;
                    trialProgressBar.style.width = `${trialProgress}%`;
                    trialProgressText.textContent = `Trial ${trialNum} / ${trials}`;
                }
                
                const trialResults = strategies.map(s => ({
                    id: s.id, name: s.name, totalScore: 0, wins: 0, losses: 0, ties: 0,
                    totalCoop: 0, totalIterations: 0, matches: 0, scores: {}
                }));

                const trialScoreMatrix = {};
                strategies.forEach(s1 => {
                    trialScoreMatrix[s1.id] = {};
                    strategies.forEach(s2 => { trialScoreMatrix[s1.id][s2.id] = 0; });
                });

                let matchCount = 0;

                function runNextMatch(idx1, idx2) {
                    if (idx1 >= strategies.length) {
                        trialResults.forEach((r, i) => {
                            accumulatedResults[i].totalScore += r.totalScore;
                            accumulatedResults[i].wins += r.wins;
                            accumulatedResults[i].losses += r.losses;
                            accumulatedResults[i].ties += r.ties;
                            accumulatedResults[i].totalCoop += r.totalCoop;
                            accumulatedResults[i].totalIterations += r.totalIterations;
                            accumulatedResults[i].matches += r.matches;
                            for (let key in r.scores) {
                                accumulatedResults[i].scores[key] = (accumulatedResults[i].scores[key] || 0) + r.scores[key];
                            }
                        });

                        strategies.forEach(s1 => {
                            strategies.forEach(s2 => {
                                scoreMatrix[s1.id][s2.id] += trialScoreMatrix[s1.id][s2.id];
                            });
                        });

                        if (trialNum < trials) {
                            setTimeout(() => runTrial(trialNum + 1), 10);
                        } else {
                            displayTournamentResults(accumulatedResults, scoreMatrix, trials);
                            progressContainer.classList.add('hidden');
                        }
                        return;
                    }

                    if (idx2 >= strategies.length) {
                        runNextMatch(idx1 + 1, 0);
                        return;
                    }

                    const s1 = strategies[idx1];
                    const s2 = strategies[idx2];
                    const matchIterations = getRandomIterations();
                    
                    matchCount++;
                    const matchProgress = (matchCount / totalMatches) * 100;
                    progressBar.style.width = `${matchProgress}%`;
                    progressText.textContent = `Match ${matchCount} / ${totalMatches} (${matchIterations} iter)`;
                    
                    const result = runMatch(s1.id, s2.id, matchIterations, noiseProb);
                    
                    const r1 = trialResults.find(r => r.id === s1.id);
                    const r2 = trialResults.find(r => r.id === s2.id);
                    
                    r1.totalScore += result.p1Score;
                    r1.totalCoop += result.p1CoopRate;
                    r1.totalIterations += result.actualIterations;
                    r1.matches++;
                    r1.scores[s2.id] = result.p1Score;
                    
                    r2.totalScore += result.p2Score;
                    r2.totalCoop += result.p2CoopRate;
                    r2.totalIterations += result.actualIterations;
                    r2.matches++;
                    r2.scores[s1.id] = result.p2Score;
                    
                    trialScoreMatrix[s1.id][s2.id] = result.p1Score;

                    if (result.p1Score > result.p2Score) { r1.wins++; r2.losses++; }
                    else if (result.p2Score > result.p1Score) { r2.wins++; r1.losses++; }
                    else { r1.ties++; r2.ties++; }

                    setTimeout(() => runNextMatch(idx1, idx2 + 1), 5);
                }

                runNextMatch(0, 0);
            }

            runTrial(1);
        }

        function displayTournamentResults(results, scoreMatrix, numTrials) {
            const tournamentContainer = document.getElementById('tournament-container');
            tournamentContainer.classList.remove('hidden');
            
            document.getElementById('tournament-iterations').textContent = baseIterations;
            document.getElementById('tournament-deviation').textContent = Math.round(iterationDeviation * 100) + '%';
            
            if (numTrials > 1) {
                document.getElementById('tournament-trials-text').textContent = `Averaged over ${numTrials} trial(s). `;
            } else {
                document.getElementById('tournament-trials-text').textContent = '';
            }

            const sortedResults = [...results].sort((a, b) => b.totalScore - a.totalScore);

            sortedResults.forEach(r => {
                r.avgScore = r.matches > 0 ? (r.totalScore / r.matches).toFixed(2) : 0;
                r.avgCoop = r.matches > 0 ? (r.totalCoop / r.matches).toFixed(1) : 0;
                r.avgIterations = r.matches > 0 ? Math.round(r.totalIterations / r.matches) : 0;
            });

            const tbody = document.getElementById('tournament-body');
            tbody.innerHTML = '';
            
            sortedResults.forEach((result, index) => {
                const row = document.createElement('tr');
                row.className = `tournament-row border-b ${index === 0 ? 'winner' : ''}`;
                const medal = index === 0 ? '🥇' : index === 1 ? '🥈' : index === 2 ? '🥉' : (index + 1);
                
                row.innerHTML = `
                    <td class="p-3 font-bold">${medal}</td>
                    <td class="p-3 font-semibold text-gray-800">${result.name}</td>
                    <td class="p-3 text-center font-bold text-purple-600">${result.totalScore}</td>
                    <td class="p-3 text-center">${result.avgScore}</td>
                    <td class="p-3 text-center text-green-600">${result.wins}</td>
                    <td class="p-3 text-center text-red-600">${result.losses}</td>
                    <td class="p-3 text-center text-gray-600">${result.ties}</td>
                    <td class="p-3 text-center">
                        <div class="flex items-center justify-center gap-2">
                            <div class="w-16 bg-gray-200 rounded-full h-2">
                                <div class="bg-blue-500 h-2 rounded-full" style="width: ${result.avgCoop}%"></div>
                            </div>
                            <span class="text-xs">${result.avgCoop}%</span>
                        </div>
                    </td>
                `;
                tbody.appendChild(row);
            });

            const matrixTable = document.getElementById('matrix-table');
            matrixTable.innerHTML = '';
            
            const headerRow = document.createElement('tr');
            headerRow.innerHTML = '<th class="p-2 bg-gray-100">vs</th>';
            strategies.forEach(s => {
                const abbr = s.id.split('_').map(w => w[0]).join('').toUpperCase();
                headerRow.innerHTML += `<th class="p-2 bg-gray-100 text-center">${abbr}</th>`;
            });
            matrixTable.appendChild(headerRow);

            strategies.forEach(s1 => {
                const row = document.createElement('tr');
                const abbr = s1.id.split('_').map(w => w[0]).join('').toUpperCase();
                row.innerHTML = `<td class="p-2 bg-gray-50 font-semibold">${abbr}</td>`;
                
                strategies.forEach(s2 => {
                    const avgScore = scoreMatrix[s1.id][s2.id] / numTrials;
                    const maxScore = baseIterations * PAYOFF.T;
                    const intensity = avgScore / maxScore;
                    const bgColor = `rgba(255, ${Math.floor(255 * (1 - intensity))}, ${Math.floor(255 * (1 - intensity))}, ${0.3 + intensity * 0.7})`;
                    row.innerHTML += `<td class="p-2 text-center" style="background-color: ${bgColor}">${Math.round(avgScore)}</td>`;
                });
                
                matrixTable.appendChild(row);
            });
        }

        function runSimulation() {
            const progressContainer = document.getElementById('progress-container');
            const resultsContainer = document.getElementById('results-container');
            const historyContainer = document.getElementById('history-container');
            const tournamentContainer = document.getElementById('tournament-container');
            const progressLabel = document.getElementById('progress-label');
            const trialProgressContainer = document.getElementById('trial-progress-container');
            
            progressContainer.classList.remove('hidden');
            resultsContainer.classList.add('hidden');
            historyContainer.classList.add('hidden');
            tournamentContainer.classList.add('hidden');
            trialProgressContainer.classList.add('hidden');
            
            progressLabel.textContent = 'Progress';
            
            // Reset OmegaTFT state for new simulation
            omegaTftState = { deadlockCounter: 0, randomnessCounter: 0 };
            
            const actualIterations = getRandomIterations();

            let history = [];
            let p1Score = 0, p2Score = 0, p1CoopCount = 0, p2CoopCount = 0;
            let bothCoop = 0, bothDefect = 0, p1CoopP2Defect = 0, p1DefectP2Coop = 0;

            const progressBar = document.getElementById('progress-bar');
            const progressText = document.getElementById('progress-text');

            function runTurn(turn) {
                if (turn >= actualIterations) {
                    showResults(p1Score, p2Score, p1CoopCount, p2CoopCount, bothCoop, bothDefect, p1CoopP2Defect, p1DefectP2Coop, history, actualIterations);
                    progressContainer.classList.add('hidden');
                    return;
                }

                const p1History = history.map(h => ({ opponent: h.p2, self: h.p1 }));
                const p2History = history.map(h => ({ opponent: h.p1, self: h.p2 }));
                const lastP1Payoff = history.length > 0 ? history[history.length - 1].p1Score : null;
                const lastP2Payoff = history.length > 0 ? history[history.length - 1].p2Score : null;
                
                let p1Move = strategyFunctions[selectedP1](p1History, lastP1Payoff);
                let p2Move = strategyFunctions[selectedP2](p2History, lastP2Payoff);

                p1Move = applyNoise(p1Move, noiseProb);
                p2Move = applyNoise(p2Move, noiseProb);

                const payoffKey = `${p1Move}_${p2Move}`;
                const payoff = payoffs[payoffKey];

                p1Score += payoff.p1;
                p2Score += payoff.p2;
                if (p1Move === 'cooperate') p1CoopCount++;
                if (p2Move === 'cooperate') p2CoopCount++;
                if (p1Move === 'cooperate' && p2Move === 'cooperate') bothCoop++;
                if (p1Move === 'defect' && p2Move === 'defect') bothDefect++;
                if (p1Move === 'cooperate' && p2Move === 'defect') p1CoopP2Defect++;
                if (p1Move === 'defect' && p2Move === 'cooperate') p1DefectP2Coop++;

                history.push({ turn: turn + 1, p1: p1Move, p2: p2Move, p1Score: payoff.p1, p2Score: payoff.p2 });

                const progress = ((turn + 1) / actualIterations) * 100;
                progressBar.style.width = `${progress}%`;
                progressText.textContent = `${turn + 1} / ${actualIterations} iterations`;

                runTurn(turn + 1);
            }

            runTurn(0);
        }

        function showResults(p1Score, p2Score, p1CoopCount, p2CoopCount, bothCoop, bothDefect, p1CoopP2Defect, p1DefectP2Coop, history, actualIterations) {
            const resultsContainer = document.getElementById('results-container');
            const historyContainer = document.getElementById('history-container');
            
            resultsContainer.classList.remove('hidden');
            historyContainer.classList.remove('hidden');

            document.getElementById('player1-score').textContent = p1Score;
            document.getElementById('player2-score').textContent = p2Score;
            document.getElementById('player1-average').textContent = `Average: ${(p1Score / actualIterations).toFixed(2)} per turn`;
            document.getElementById('player2-average').textContent = `Average: ${(p2Score / actualIterations).toFixed(2)} per turn`;

            const p1CoopRate = (p1CoopCount / actualIterations) * 100;
            const p2CoopRate = (p2CoopCount / actualIterations) * 100;
            document.getElementById('player1-coop').textContent = `${p1CoopRate.toFixed(1)}%`;
            document.getElementById('player2-coop').textContent = `${p2CoopRate.toFixed(1)}%`;
            document.getElementById('player1-coop-bar').style.width = `${p1CoopRate}%`;
            document.getElementById('player2-coop-bar').style.width = `${p2CoopRate}%`;

            document.getElementById('both-coop').textContent = bothCoop;
            document.getElementById('both-defect').textContent = bothDefect;
            document.getElementById('p1-coop-p2-defect').textContent = p1CoopP2Defect;
            document.getElementById('p1-defect-p2-coop').textContent = p1DefectP2Coop;

            const winnerContainer = document.getElementById('winner-container');
            const winnerText = document.getElementById('winner-text');
            winnerContainer.classList.remove('hidden');
            if (p1Score > p2Score) {
                winnerContainer.className = 'text-center p-4 rounded-lg bg-blue-100';
                winnerText.textContent = `🏆 Player 1 Wins! (${actualIterations} turns)`;
                winnerText.className = 'text-xl font-bold text-blue-700';
            } else if (p2Score > p1Score) {
                winnerContainer.className = 'text-center p-4 rounded-lg bg-red-100';
                winnerText.textContent = `🏆 Player 2 Wins! (${actualIterations} turns)`;
                winnerText.className = 'text-xl font-bold text-red-700';
            } else {
                winnerContainer.className = 'text-center p-4 rounded-lg bg-gray-100';
                winnerText.textContent = `🤝 It's a Tie! (${actualIterations} turns)`;
                winnerText.className = 'text-xl font-bold text-gray-700';
            }

            const historyBody = document.getElementById('history-body');
            historyBody.innerHTML = '';
            const recentHistory = history.slice(-20);
            recentHistory.forEach(turn => {
                const row = document.createElement('tr');
                row.className = 'border-b hover:bg-gray-50';
                row.innerHTML = `
                    <td class="p-2 font-medium">${turn.turn}</td>
                    <td class="p-2">
                        <span class="px-2 py-1 rounded text-xs font-semibold ${turn.p1 === 'cooperate' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}">
                            ${turn.p1 === 'cooperate' ? 'C' : 'D'}
                        </span>
                    </td>
                    <td class="p-2">
                        <span class="px-2 py-1 rounded text-xs font-semibold ${turn.p2 === 'cooperate' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}">
                            ${turn.p2 === 'cooperate' ? 'C' : 'D'}
                        </span>
                    </td>
                    <td class="p-2 font-medium ${turn.p1Score > 0 ? 'text-green-600' : 'text-gray-600'}">${turn.p1Score}</td>
                    <td class="p-2 font-medium ${turn.p2Score > 0 ? 'text-green-600' : 'text-gray-600'}">${turn.p2Score}</td>
                `;
                historyBody.appendChild(row);
            });
        }

        function reset() {
            document.getElementById('results-container').classList.add('hidden');
            document.getElementById('history-container').classList.add('hidden');
            document.getElementById('progress-container').classList.add('hidden');
            document.getElementById('tournament-container').classList.add('hidden');
            document.getElementById('progress-bar').style.width = '0%';
            document.getElementById('trial-progress-bar').style.width = '0%';
        }

        function openAboutModal() {
            document.getElementById('about-modal').classList.add('active');
        }

        function closeAboutModal() {
            document.getElementById('about-modal').classList.remove('active');
        }

        document.getElementById('iterations').addEventListener('input', (e) => {
            baseIterations = parseInt(e.target.value);
            document.getElementById('iteration-value').textContent = baseIterations;
        });

        document.getElementById('deviation').addEventListener('input', (e) => {
            iterationDeviation = parseInt(e.target.value) / 100;
            document.getElementById('deviation-value').textContent = `${e.target.value}%`;
        });

        document.getElementById('trials').addEventListener('input', (e) => {
            trials = parseInt(e.target.value);
            document.getElementById('trials-value').textContent = trials;
        });

        document.getElementById('generous').addEventListener('input', (e) => {
            generousProb = parseInt(e.target.value) / 100;
            document.getElementById('generous-value').textContent = `${e.target.value}%`;
        });

        document.getElementById('random-prob').addEventListener('input', (e) => {
            randomCoopProb = parseInt(e.target.value) / 100;
            document.getElementById('random-prob-value').textContent = `${e.target.value}%`;
        });

        document.getElementById('imperfect-tft').addEventListener('input', (e) => {
            imperfectTftProb = parseInt(e.target.value) / 100;
            document.getElementById('imperfect-tft-value').textContent = `${e.target.value}%`;
        });

        document.getElementById('reactive-p').addEventListener('input', (e) => {
            reactiveP = parseInt(e.target.value) / 100;
            document.getElementById('reactive-p-value').textContent = `${e.target.value}%`;
        });

        document.getElementById('reactive-q').addEventListener('input', (e) => {
            reactiveQ = parseInt(e.target.value) / 100;
            document.getElementById('reactive-q-value').textContent = `${e.target.value}%`;
        });

        document.getElementById('noise').addEventListener('input', (e) => {
            noiseProb = parseFloat(e.target.value) / 100;
            document.getElementById('noise-value').textContent = `${e.target.value}%`;
        });

        document.getElementById('gradual-apologies').addEventListener('input', (e) => {
            gradualApologies = parseInt(e.target.value);
            document.getElementById('gradual-apologies-value').textContent = gradualApologies;
        });

        document.getElementById('fully-gradual-apologies-max').addEventListener('input', (e) => {
            fullyGradualApologiesMax = parseInt(e.target.value);
            document.getElementById('fully-gradual-apologies-max-value').textContent = fullyGradualApologiesMax;
        });

        document.getElementById('run-btn').addEventListener('click', () => { reset(); runSimulation(); });
        document.getElementById('tournament-btn').addEventListener('click', () => { reset(); runTournament(); });
        document.getElementById('reset-btn').addEventListener('click', reset);
        document.getElementById('about-btn').addEventListener('click', openAboutModal);
        document.getElementById('close-modal-btn').addEventListener('click', closeAboutModal);
        document.getElementById('about-modal').addEventListener('click', (e) => {
            if (e.target.id === 'about-modal') closeAboutModal();
        });

        initializeStrategySelectors();
    </script>
</body>
</html>

