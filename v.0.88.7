                        omegaTftState.randomnessCounter += 1;
                    }

                    // If the opponent's last move differed from mine, increase the counter
                    if (history[history.length - 1].self !== history[history.length - 1].opponent) {
                        omegaTftState.randomnessCounter += 1;
