        function getRandomIterations() {
            const minIter = Math.floor(baseIterations * (1 - iterationDeviation));
            const maxIter = Math.floor(baseIterations * (1 + iterationDeviation));
            return Math.floor(Math.random() * (maxIter - minIter + 1)) + minIter;
        }

        function applyNoise(move, noise) {
            if (Math.random() < noise) {
                return move === 'cooperate' ? 'defect' : 'cooperate';
            }
            return move;
        }

        function countDefectionWaves(history) {
            let waves = 0;
            let inWave = false;
            for (let i = 0; i < history.length; i++) {
                if (history[i].opponent === 'defect' && !inWave) {
                    waves++;
                    inWave = true;
                } else if (history[i].opponent === 'cooperate') {
                    inWave = false;
                }
            }
            return waves;
        }

        const strategyFunctions = {
